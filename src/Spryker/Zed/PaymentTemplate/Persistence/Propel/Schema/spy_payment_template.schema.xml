<?xml version="1.0"?>
<database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          name="zed"
          xsi:noNamespaceSchemaLocation="http://static.spryker.com/schema-01.xsd"
          namespace="Orm\Zed\PaymentTemplate\Persistence"
          package="src.Orm.Zed.PaymentTemplate.Persistence">

    <table name="spy_payment_template" idMethod="native" allowPkInsert="true">
        <column name="id_payment_template" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="fk_sales_order" required="true" type="INTEGER"/>

        <!-- TODO add your PSP-specific fields. -->

        <foreign-key name="spy_payment_template-fk_sales_order" foreignTable="spy_sales_order" phpName="SpySalesOrder">
            <reference foreign="id_sales_order" local="fk_sales_order"/>
        </foreign-key>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_payment_template_pk_seq"/>
    </table>

    <table name="spy_payment_template_order_item" idMethod="native" allowPkInsert="true">
        <column name="id_payment_template_order_item" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="fk_payment_template" type="INTEGER" required="true"/>
        <column name="fk_sales_order_item" type="INTEGER" required="true"/>

        <foreign-key name="spy_payment_template_order_item-fk_payment" foreignTable="spy_payment_template">
            <reference foreign="id_payment_template" local="fk_payment_template"/>
        </foreign-key>

        <foreign-key name="spy_payment_template_order_item-fk_order_item" foreignTable="spy_sales_order_item">
            <reference foreign="id_sales_order_item" local="fk_sales_order_item"/>
        </foreign-key>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_payment_template_order_item_pk_seq"/>
    </table>

    <table name="spy_payment_template_notification" idMethod="native" allowPkInsert="true">
        <column name="id_payment_template_notification" required="true" type="INTEGER" primaryKey="true" autoIncrement="true"/>
        <column name="payload" required="false" type="LONGVARCHAR"/>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_payment_template_notification_pk_seq"/>
    </table>

</database>
