<?xml version="1.0"?>
<statemachine
    xmlns="spryker:oms-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:oms-01 http://static.spryker.com/oms-01.xsd">

    <process name="PaymentTemplateCreditCard01" main="true">

        <!-- ====================================================================
             STATES
             ==================================================================== -->

        <states>
            <state name="new" display="oms.state.new"/>
            <state name="processing" display="oms.state.processing" reserved="true"/>
            <state name="authorization pending" display="oms.state.authorization-pending"/>
            <state name="authorization failed" display="oms.state.authorization-failed"/>
            <state name="authorized" display="oms.state.authorized"/>
            <state name="capture pending" display="oms.state.capture-pending"/>
            <state name="captured" display="oms.state.captured"/>
            <state name="refund pending" display="oms.state.refund-pending"/>
            <state name="refunded" display="oms.state.refunded"/>
            <state name="closed for refund" display="oms.state.closed-for-refund"/>
            <state name="canceled" display="oms.state.canceled"/>
        </states>

        <!-- ====================================================================
             TRANSITIONS
             ==================================================================== -->

        <transitions>
            <!-- Initial state transition. Can be removed Once the rest of OMS is implemented. -->
            <transition happy="true">
                <source>new</source>
                <target>processing</target>
                <event>wait</event>
            </transition>

            <!-- Authorize -->
            <transition happy="true">
                <source>processing</source>
                <target>authorization pending</target>
                <event>authorize</event>
            </transition>

            <!-- Authorization result (checked via webhook) -->
            <transition happy="true" condition="PaymentTemplate/IsAuthorized">
                <source>authorization pending</source>
                <target>authorized</target>
            </transition>

            <transition condition="PaymentTemplate/IsAuthorizationFailed">
                <source>authorization pending</source>
                <target>authorization failed</target>
            </transition>

            <!-- Capture -->
            <transition happy="true">
                <source>authorized</source>
                <target>capture pending</target>
                <event>capture</event>
            </transition>

            <transition happy="true" condition="PaymentTemplate/IsCaptured">
                <source>capture pending</source>
                <target>captured</target>
            </transition>

            <!-- Refund -->
            <transition happy="true">
                <source>captured</source>
                <target>refund pending</target>
                <event>refund</event>
            </transition>

            <transition happy="true" condition="PaymentTemplate/IsRefunded">
                <source>refund pending</source>
                <target>refunded</target>
            </transition>

            <transition happy="true">
                <source>captured</source>
                <target>closed for refund</target>
                <event>close for refund</event>
            </transition>

            <!-- Cancel -->
            <transition>
                <source>authorized</source>
                <target>canceled</target>
                <event>cancel</event>
            </transition>
        </transitions>

        <!-- ====================================================================
             EVENTS
             ==================================================================== -->

        <events>
            <event name="wait" timeout="1 second"/>
            <event name="authorize" manual="true" onEnter="true" command="PaymentTemplate/Authorize"/>
            <event name="capture" manual="true" onEnter="true" command="PaymentTemplate/Capture"/>
            <event name="refund" manual="true" command="PaymentTemplate/Refund"/>
            <event name="close for refund" timeout="30 days"/>
            <event name="cancel" manual="true" command="PaymentTemplate/Cancel"/>
        </events>

    </process>

</statemachine>
